rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Kimlik ve kullanıcı bağlamı ───────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentRole() {
      return hasUserDoc() ? currentUser().role : '';
    }

    function currentCompanyId() {
      return hasUserDoc() ? currentUser().companyId : '';
    }

    function currentRegisteredCompanies() {
      return hasUserDoc() && currentUser().registeredCompanies != null
        ? currentUser().registeredCompanies
        : [];
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return currentRole() == 'super_admin';
    }

    function isAdmin() {
      return currentRole() == 'admin';
    }

    function isGuide() {
      return currentRole() == 'guide';
    }

    function isCustomer() {
      return currentRole() == 'customer';
    }

    function belongsToCurrentCompany(companyId) {
      return isSignedIn() && currentCompanyId() == companyId;
    }

    function canViewCompany(companyId) {
      return isSuperAdmin() ||
        belongsToCurrentCompany(companyId) ||
        companyId in currentRegisteredCompanies();
    }

    function tourDoc(tourId) {
      return get(/databases/$(database)/documents/tours/$(tourId)).data;
    }

    function hasTour(tourId) {
      return exists(/databases/$(database)/documents/tours/$(tourId));
    }

    function canManageCompany(companyId) {
      return isSuperAdmin() || (isAdmin() && belongsToCurrentCompany(companyId));
    }

    function userBelongsToCurrentCompany(userData) {
      return hasUserDoc() && (
        userData.companyId == currentCompanyId() ||
        (userData.registeredCompanies != null && currentCompanyId() in userData.registeredCompanies)
      );
    }

    function ticketBelongsToCurrentCompany(ticketData) {
      return ticketData.companyId == currentCompanyId() ||
        (ticketData.tourId is string &&
          hasTour(ticketData.tourId) &&
          tourDoc(ticketData.tourId).companyId == currentCompanyId());
    }

    function canReadTours() {
      // Tur listesi herkese açık: giriş yapan da yapmayan da turları görebilmeli.
      return true;
    }

    function isGuideForTour(tourId) {
      return isGuide() && hasTour(tourId) && tourDoc(tourId).guideId == request.auth.uid;
    }

    function isCustomerPurchaseCapacityDecrease() {
      return isCustomer() &&
        request.resource.data.capacity is int &&
        resource.data.capacity is int &&
        resource.data.capacity > 0 &&
        request.resource.data.capacity == resource.data.capacity - 1 &&
        request.resource.data.companyId == resource.data.companyId &&
        request.resource.data.isDeleted == resource.data.isDeleted &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['capacity']);
    }

    function canReadNotificationTarget(targetCompanyId, isBroadcast) {
      return isSuperAdmin() ||
        (hasUserDoc() && isBroadcast == true) ||
        canViewCompany(targetCompanyId);
    }

    function isCustomerOwnTicketCreate() {
      return isCustomer() &&
        request.resource.data.userId == request.auth.uid &&
        hasTour(request.resource.data.tourId) &&
        request.resource.data.companyId == tourDoc(request.resource.data.tourId).companyId &&
        (!request.resource.data.keys().hasAny(['isScanned']) ||
          request.resource.data.isScanned == false) &&
        (!request.resource.data.keys().hasAny(['status']) ||
          request.resource.data.status in ['active', 'pending']);
    }

    function isCustomerOwnTicketCancel() {
      return isCustomer() &&
        isSelf(resource.data.userId) &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.tourId == resource.data.tourId &&
        request.resource.data.companyId == resource.data.companyId &&
        request.resource.data.slotId == resource.data.slotId &&
        request.resource.data.passengerName == resource.data.passengerName &&
        request.resource.data.tcNo == resource.data.tcNo &&
        request.resource.data.pricePaid == resource.data.pricePaid &&
        request.resource.data.qrToken == resource.data.qrToken &&
        request.resource.data.isScanned == resource.data.isScanned &&
        request.resource.data.purchaseDate == resource.data.purchaseDate &&
        request.resource.data.scannedAt == resource.data.scannedAt &&
        request.resource.data.departureDate == resource.data.departureDate;
    }

    function preservesOwnUserSecurityFields() {
      return request.resource.data.role == resource.data.role &&
        request.resource.data.companyId == resource.data.companyId &&
        request.resource.data.registeredCompanies == resource.data.registeredCompanies &&
        request.resource.data.isDeleted == resource.data.isDeleted &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.loginId == resource.data.loginId &&
        request.resource.data.customerPassword == resource.data.customerPassword &&
        request.resource.data.guidePassword == resource.data.guidePassword &&
        request.resource.data.isPanelManagedCustomer == resource.data.isPanelManagedCustomer;
    }

    function guideOwnsTourRequest(tourId, companyId) {
      return isGuideForTour(tourId) && tourDoc(tourId).companyId == companyId;
    }

    // ─── Şirketler ─────────────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if canViewCompany(companyId);
      allow create, update, delete: if isSuperAdmin();
    }

    // ─── Kullanıcılar ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSuperAdmin() ||
        isSelf(userId) ||
        (isAdmin() && userBelongsToCurrentCompany(resource.data));

      allow create: if isSuperAdmin() ||
        (isAdmin() &&
          userBelongsToCurrentCompany(request.resource.data) &&
          request.resource.data.role in ['guide', 'customer']);

      allow update: if isSuperAdmin() ||
        (isSelf(userId) && preservesOwnUserSecurityFields()) ||
        (isAdmin() &&
          userBelongsToCurrentCompany(resource.data) &&
          userBelongsToCurrentCompany(request.resource.data) &&
          request.resource.data.role == resource.data.role &&
          resource.data.role != 'super_admin');

      allow delete: if isSuperAdmin();
    }

    // ─── Turlar ────────────────────────────────────────────────────────────
    match /tours/{tourId} {
      allow read: if canReadTours();

      allow create: if isSuperAdmin() ||
        (isAdmin() && request.resource.data.companyId == currentCompanyId());

      allow update: if isSuperAdmin() ||
        (isAdmin() &&
          resource.data.companyId == currentCompanyId() &&
          request.resource.data.companyId == resource.data.companyId) ||
        isCustomerPurchaseCapacityDecrease();

      allow delete: if isSuperAdmin() ||
        (isAdmin() &&
          resource.data.companyId == currentCompanyId() &&
          request.resource.data.companyId == resource.data.companyId);

      match /messages/{messageId} {
        allow read: if canReadTours();

        // Customers can post messages (chat) in tours they are participating in.
        // The isScanned enforcement is handled at the app layer since Firestore
        // rules cannot query tickets by userId+tourId without a known doc ID.
        allow create: if isSuperAdmin() ||
          (isAdmin() && tourDoc(tourId).companyId == currentCompanyId()) ||
          isGuideForTour(tourId) ||
          isCustomer();

        allow update, delete: if isSuperAdmin() ||
          (isAdmin() && tourDoc(tourId).companyId == currentCompanyId()) ||
          isGuideForTour(tourId);
      }

      match /announcements/{announcementId} {
        allow read: if canReadTours();

        allow create, update, delete: if isSuperAdmin() ||
          (isAdmin() && tourDoc(tourId).companyId == currentCompanyId()) ||
          isGuideForTour(tourId);
      }
    }

    // ─── Biletler ──────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read: if isSuperAdmin() ||
        (isAdmin() && ticketBelongsToCurrentCompany(resource.data)) ||
        isSelf(resource.data.userId) ||
        isGuideForTour(resource.data.tourId);

      allow create: if isSuperAdmin() ||
        (isAdmin() &&
          request.resource.data.companyId == currentCompanyId() &&
          hasTour(request.resource.data.tourId) &&
          tourDoc(request.resource.data.tourId).companyId == currentCompanyId()) ||
        // Customer self-purchase: ticket must belong to the buyer, tour must exist,
        // companyId must match the tour, and ticket starts un-scanned.
        isCustomerOwnTicketCreate();

      allow update: if isSuperAdmin() ||
        (isAdmin() &&
          ticketBelongsToCurrentCompany(resource.data) &&
          ticketBelongsToCurrentCompany(request.resource.data) &&
          request.resource.data.tourId == resource.data.tourId &&
          request.resource.data.userId == resource.data.userId) ||
        (isGuideForTour(resource.data.tourId) &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.tourId == resource.data.tourId &&
          request.resource.data.userId == resource.data.userId) ||
        // Customer can cancel their own ticket (status → 'cancelled');
        // all other fields must remain unchanged.
        isCustomerOwnTicketCancel();

      allow delete: if isSuperAdmin() ||
        (isAdmin() && ticketBelongsToCurrentCompany(resource.data));
    }

    // ─── Bildirimler ───────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if canReadNotificationTarget(
        resource.data.targetCompanyId,
        resource.data.isBroadcast,
      );

      allow create: if
        (isSuperAdmin() && request.resource.data.senderRole == 'super_admin') ||
        // Guide can broadcast notifications to their own company (e.g. to scanned
        // customers on their tour). targetCompanyId must match the guide's company.
        (isGuide() &&
          request.resource.data.senderRole == 'guide' &&
          request.resource.data.targetCompanyId == currentCompanyId());

      allow update: if isSuperAdmin() ||
        (canReadNotificationTarget(resource.data.targetCompanyId, resource.data.isBroadcast) &&
          request.resource.data.targetCompanyId == resource.data.targetCompanyId &&
          request.resource.data.isBroadcast == resource.data.isBroadcast &&
          request.resource.data.senderRole == resource.data.senderRole &&
          request.resource.data.title == resource.data.title &&
          request.resource.data.body == resource.data.body &&
          request.resource.data.createdAt == resource.data.createdAt);

      allow delete: if isSuperAdmin();
    }

    // ─── Geri Bildirimler ──────────────────────────────────────────────────
    match /feedbacks/{feedbackId} {
      allow read: if isSuperAdmin() ||
        (isAdmin() && resource.data.companyId == currentCompanyId());

      allow create: if isAdmin() &&
        request.resource.data.companyId == currentCompanyId();

      allow update, delete: if isSuperAdmin();
    }

    // ─── Tur Bitirme İstekleri ─────────────────────────────────────────────
    match /tourCompletionRequests/{reqId} {
      allow read: if isSuperAdmin() ||
        (isAdmin() && resource.data.companyId == currentCompanyId()) ||
        isSelf(resource.data.guideId);

      allow create: if isGuide() &&
        request.resource.data.guideId == request.auth.uid &&
        guideOwnsTourRequest(
          request.resource.data.tourId,
          request.resource.data.companyId,
        );

      allow update: if isSuperAdmin() ||
        (isAdmin() &&
          resource.data.companyId == currentCompanyId() &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.tourId == resource.data.tourId &&
          request.resource.data.guideId == resource.data.guideId);

      allow delete: if isSuperAdmin() ||
        (isAdmin() && resource.data.companyId == currentCompanyId());
    }

    match /tour_completion_requests/{reqId} {
      allow read: if isSuperAdmin() ||
        (isAdmin() && resource.data.companyId == currentCompanyId()) ||
        isSelf(resource.data.guideId);

      allow create: if isGuide() &&
        request.resource.data.guideId == request.auth.uid &&
        guideOwnsTourRequest(
          request.resource.data.tourId,
          request.resource.data.companyId,
        );

      allow update: if isSuperAdmin() ||
        (isAdmin() &&
          resource.data.companyId == currentCompanyId() &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.tourId == resource.data.tourId &&
          request.resource.data.guideId == resource.data.guideId);

      allow delete: if isSuperAdmin() ||
        (isAdmin() && resource.data.companyId == currentCompanyId());
    }

    // ─── Super Admin: tam erişim ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
